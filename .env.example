# ---------------------------------------------------------------------------
# CDMAS environment configuration. Copy to `.env` and adjust as needed.
# ---------------------------------------------------------------------------

# --- Message bus (Kafka) ---
CDMAS_KAFKA_BOOTSTRAP=localhost:9092
CDMAS_KAFKA_CLIENT_ID=cdmas

# --- Simulator REST API ---
CDMAS_SIM_HOST=0.0.0.0
CDMAS_SIM_PORT=8000
CDMAS_SIM_BASE_URL=http://localhost:8000
# Per-agent auth token for the simulator API (rate-limited per agent).
CDMAS_SIM_API_TOKEN=changeme

# --- Simulation clock ---
# Speed multiplier: 1.0 = real time, 0.5 = slow, up to 10.0 = accelerated.
CDMAS_SIM_SPEED=1.0
CDMAS_SIM_TICK_MS=10

# --- Event log persistence (PostgreSQL) ---
CDMAS_DB_URL=postgresql+asyncpg://cdmas:cdmas@localhost:5432/cdmas

# --- Logging ---
CDMAS_LOG_LEVEL=INFO
CDMAS_LOG_JSON=true

# --- Agent identity (set per-container) ---
# CDMAS_AGENT_ID=ACA:seg1
# CDMAS_AGENT_SEGMENT=public-facing
